# happen to be named ".env" in this repo (Arbitrage, OmniAgent, cryptonn,
# eye-tracking, object_detection_with_llm, tellama).
.env
.env.*
!.env.example
.envrc

# Other common venv directory names
.venv/
venv/
env/
ENV/

